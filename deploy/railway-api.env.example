# Railway API service variables (copy to Railway -> Service -> Variables)
DATABASE_URL=postgresql://...
JWT_SECRET=replace_with_a_long_random_secret
NODE_ENV=production
ALLOWED_ORIGINS=https://frontend-service-name.up.railway.app,http://localhost:5173
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

# Statement e-mail - ONERILENYON: Resend API (SMTP port sorunu olmaz, Railway dahil her yerde calısır)
# 1. https://resend.com adresinden ucretsiz hesap ac (3000 email/ay)
# 2. Hesap > API Keys > API Key olustur
# 3. Asagidaki RESEND_API_KEY degerini gir
# 4. Resend > Domains veya Emails sekmesinden gonderici adresini dogrula
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
STATEMENT_EMAIL_FROM=your.address@gmail.com
STATEMENT_EMAIL_FROM_NAME=ApartmanWeb

# Statement e-mail - ALTERNATIF: SMTP (Resend API key ayarli degilse bu kullanilir)
# Railway SMTP port 465'i CAP IYI ENGELLER. Port 587 kullaniniz.
STATEMENT_EMAIL_SMTP_HOST=smtp.gmail.com
STATEMENT_EMAIL_SMTP_PORT=587
STATEMENT_EMAIL_SMTP_SECURE=false
STATEMENT_EMAIL_SMTP_REQUIRE_TLS=true
STATEMENT_EMAIL_DNS_RESULT_ORDER=ipv4first
STATEMENT_EMAIL_CONNECTION_TIMEOUT_MS=20000
STATEMENT_EMAIL_GREETING_TIMEOUT_MS=10000
STATEMENT_EMAIL_SOCKET_TIMEOUT_MS=20000
STATEMENT_EMAIL_SMTP_USER=your.address@gmail.com
STATEMENT_EMAIL_SMTP_PASS=

# Gmail bank statement auto-sync (optional)
GMAIL_BANK_SYNC_ENABLED=false
GMAIL_BANK_SYNC_CRON_TOKEN=
GMAIL_USER=your.address@gmail.com
GMAIL_APP_PASSWORD=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_BANK_SENDER=
GMAIL_BANK_SUBJECT_CONTAINS=
ISBANK_EMAIL_FROM=
GMAIL_BANK_QUERY=
GMAIL_BANK_IMPORT_ONLY_INCOMING=true
GMAIL_BANK_LOOKBACK_DAYS=2
GMAIL_BANK_MAX_MESSAGES=10
GMAIL_BANK_SYNC_SCHEDULE_HOUR=12
GMAIL_BANK_SYNC_SCHEDULE_MINUTE=0
GMAIL_BANK_SYNC_TIMEZONE=Europe/Istanbul
