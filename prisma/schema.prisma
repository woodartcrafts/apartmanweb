generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  RESIDENT
}

enum ApartmentType {
  KUCUK
  BUYUK
}

enum OccupancyType {
  OWNER
  TENANT
}

enum ChargePayerTarget {
  OWNER
  TENANT
}

enum ChargeStatus {
  OPEN
  CLOSED
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  CREDIT_CARD
  OTHER
}

enum ImportBatchType {
  PAYMENT_UPLOAD
  BANK_STATEMENT_UPLOAD
}

enum AuditActionType {
  EDIT
  DELETE
  UNDO
}

enum AuditEntityType {
  PAYMENT
  EXPENSE
}

enum AuditUndoKind {
  PAYMENT_EDIT
  PAYMENT_DELETE
  EXPENSE_EDIT
  EXPENSE_DELETE
}

enum ApartmentChangeAction {
  CREATE
  UPDATE
  BULK_UPDATE_CLASS
}

enum PasswordChangeReason {
  INITIAL_SEED
  ADMIN_SET
  SELF_CHANGE
}

model Block {
  id        String    @id @default(cuid())
  name      String
  apartments Apartment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([name])
}

model Apartment {
  id            String      @id @default(cuid())
  blockId       String
  apartmentClassId String?
  apartmentDutyId String?
  doorNo        String
  m2            Float?
  type          ApartmentType @default(BUYUK)
  hasAidat      Boolean       @default(true)
  hasDogalgaz   Boolean       @default(true)
  hasOtherDues  Boolean       @default(true)
  hasIncome     Boolean       @default(true)
  hasExpenses   Boolean       @default(true)
  ownerFullName String?
  occupancyType OccupancyType @default(OWNER)
  email1        String?
  email2        String?
  email3        String?
  phone1        String?
  phone2        String?
  phone3        String?
  landlordFullName String?
  landlordPhone String?
  landlordEmail String?
  users         User[]
  charges       Charge[]
  changeLogs    ApartmentChangeLog[]
  apartmentClass ApartmentClassDefinition? @relation(fields: [apartmentClassId], references: [id], onDelete: SetNull)
  apartmentDuty ApartmentDutyDefinition? @relation(fields: [apartmentDutyId], references: [id], onDelete: SetNull)
  block         Block       @relation(fields: [blockId], references: [id], onDelete: Restrict)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([blockId, doorNo])
  @@index([doorNo])
  @@index([apartmentClassId])
  @@index([apartmentDutyId])
}

model ApartmentClassDefinition {
  id        String      @id @default(cuid())
  code      String      @unique
  name      String
  isActive  Boolean     @default(true)
  apartments Apartment[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model ApartmentDutyDefinition {
  id         String      @id @default(cuid())
  code       String      @unique
  name       String
  isActive   Boolean     @default(true)
  apartments Apartment[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model ApartmentTypeDefinition {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BankDefinition {
  id        String                @id @default(cuid())
  name      String                @unique
  isActive  Boolean               @default(true)
  branches  BankBranchDefinition[]
  termDeposits BankTermDeposit[]
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
}

model BankBranchDefinition {
  id                 String         @id @default(cuid())
  bankId             String
  name               String
  branchCode         String?
  accountName        String?
  accountNumber      String?
  iban               String?
  phone              String?
  email              String?
  address            String?
  representativeName String?
  representativePhone String?
  representativeEmail String?
  notes              String?
  isActive           Boolean        @default(true)
  bank               BankDefinition @relation(fields: [bankId], references: [id], onDelete: Restrict)
  termDeposits       BankTermDeposit[]
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@unique([bankId, name])
  @@index([bankId])
}

model BankTermDeposit {
  id                  String               @id @default(cuid())
  bankId              String
  branchId            String?
  principalAmount     Decimal              @db.Decimal(14, 2)
  annualInterestRate  Decimal              @db.Decimal(7, 4)
  withholdingTaxRate  Decimal              @db.Decimal(7, 4)
  startDate           DateTime
  endDate             DateTime
  notes               String?
  isActive            Boolean              @default(true)
  bank                BankDefinition       @relation(fields: [bankId], references: [id], onDelete: Restrict)
  branch              BankBranchDefinition? @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([bankId])
  @@index([branchId])
  @@index([endDate])
}

model BuildingProfile {
  id                       String   @id @default(cuid())
  singletonKey             String   @unique @default("DEFAULT")
  buildingName             String?
  parcelInfo               String?
  address                  String?
  totalIndependentSections Int?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model DescriptionDoorNoRule {
  id                String   @id @default(cuid())
  keyword           String
  normalizedKeyword String   @unique
  doorNo            String
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([isActive])
  @@index([doorNo])
}

model DescriptionExpenseRule {
  id                String                @id @default(cuid())
  keyword           String
  normalizedKeyword String                @unique
  expenseItemId     String
  isActive          Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  expenseItem       ExpenseItemDefinition @relation(fields: [expenseItemId], references: [id], onDelete: Restrict)

  @@index([isActive])
  @@index([expenseItemId])
}

model User {
  id           String     @id @default(cuid())
  apartmentId  String?
  fullName     String
  email        String     @unique
  phone        String?    @unique
  passwordHash String
  passwordPlaintext String?
  role         UserRole
  apartment    Apartment? @relation(fields: [apartmentId], references: [id], onDelete: SetNull)
  importBatches ImportBatch[]
  auditLogs     AuditActionLog[]
  apartmentChangeLogs ApartmentChangeLog[]
  passwordHistoryAsSubject UserPasswordHistory[] @relation("PasswordHistorySubject")
  passwordHistoryAsActor UserPasswordHistory[] @relation("PasswordHistoryActor")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([role])
}

model UserPasswordHistory {
  id               String               @id @default(cuid())
  userId           String
  changedByUserId  String?
  passwordHash     String
  passwordPlaintext String?
  reason           PasswordChangeReason
  changedAt        DateTime             @default(now())
  user             User                 @relation("PasswordHistorySubject", fields: [userId], references: [id], onDelete: Cascade)
  changedBy        User?                @relation("PasswordHistoryActor", fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([userId, changedAt])
  @@index([changedByUserId, changedAt])
  @@index([changedAt])
}

model AuditActionLog {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now())
  undoUntil   DateTime?
  undoneAt    DateTime?
  actionType  AuditActionType
  entityType  AuditEntityType
  entityId    String
  actorUserId String?
  before      Json
  after       Json
  undoKind    AuditUndoKind?
  undoPayload Json?
  actor       User?           @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([undoUntil])
  @@index([actorUserId])
  @@index([entityType, entityId])
}

model ApartmentChangeLog {
  id              String                @id @default(cuid())
  apartmentId     String
  changedAt       DateTime              @default(now())
  changedByUserId String?
  action          ApartmentChangeAction @default(UPDATE)
  changedFields   String[]
  before          Json
  after           Json
  note            String?
  apartment       Apartment             @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  changedBy       User?                 @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)

  @@index([apartmentId, changedAt])
  @@index([changedByUserId])
}

model Charge {
  id              String       @id @default(cuid())
  apartmentId     String
  chargeTypeId    String
  periodYear      Int
  periodMonth     Int
  description     String?
  amount          Decimal      @db.Decimal(12, 2)
  dueDate         DateTime
  status          ChargeStatus @default(OPEN)
  closedAt        DateTime?
  apartment       Apartment    @relation(fields: [apartmentId], references: [id], onDelete: Restrict)
  chargeType      ChargeTypeDefinition @relation(fields: [chargeTypeId], references: [id], onDelete: Restrict)
  paymentItems    PaymentItem[]
  createdByUserId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([apartmentId, periodYear, periodMonth])
  @@index([status])
  @@index([chargeTypeId])
}

model ChargeTypeDefinition {
  id           String            @id @default(cuid())
  code         String            @unique
  name         String
  payerTarget  ChargePayerTarget @default(OWNER)
  isActive     Boolean           @default(true)
  charges      Charge[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model ExpenseItemDefinition {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  expenses  Expense[]
  descriptionExpenseRules DescriptionExpenseRule[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expense {
  id            String                @id @default(cuid())
  expenseItemId String
  importBatchId String?
  spentAt       DateTime
  amount        Decimal               @db.Decimal(12, 2)
  paymentMethod PaymentMethod         @default(CASH)
  description   String?
  reference     String?
  createdById   String?
  createdAt     DateTime              @default(now())
  expenseItem   ExpenseItemDefinition @relation(fields: [expenseItemId], references: [id], onDelete: Restrict)
  importBatch   ImportBatch?          @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  @@index([spentAt])
  @@index([expenseItemId])
  @@index([paymentMethod])
  @@index([importBatchId])
  @@index([reference])
}

model PaymentMethodDefinition {
  id        String        @id @default(cuid())
  code      PaymentMethod @unique
  name      String
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Payment {
  id          String        @id @default(cuid())
  importBatchId String?
  paidAt      DateTime
  totalAmount Decimal       @db.Decimal(12, 2)
  method      PaymentMethod @default(BANK_TRANSFER)
  note        String?
  importBatch ImportBatch?  @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  itemLinks   PaymentItem[]
  createdById String?
  createdAt   DateTime      @default(now())

  @@index([importBatchId])
  @@index([paidAt])
  @@index([method])
}

model ImportBatch {
  id                  String          @id @default(cuid())
  kind                ImportBatchType
  fileName            String
  uploadedById        String?
  uploadedAt          DateTime        @default(now())
  totalRows           Int             @default(0)
  createdPaymentCount Int             @default(0)
  createdExpenseCount Int             @default(0)
  skippedCount        Int             @default(0)
  uploadedBy          User?           @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  payments            Payment[]
  expenses            Expense[]

  @@index([uploadedAt])
  @@index([uploadedById])
  @@index([kind])
  @@index([kind, uploadedAt])
  @@index([uploadedById, uploadedAt])
}

model PaymentItem {
  id        String   @id @default(cuid())
  paymentId String
  chargeId  String
  amount    Decimal  @db.Decimal(12, 2)
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  charge    Charge   @relation(fields: [chargeId], references: [id], onDelete: Restrict)

  @@index([chargeId])
  @@index([paymentId])
}

model ResidentAnnouncement {
  id          String   @id @default(cuid())
  title       String
  content     String
  isActive    Boolean  @default(true)
  publishAt   DateTime @default(now())
  expiresAt   DateTime?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, publishAt])
  @@index([expiresAt])
}

model ResidentPoll {
  id            String               @id @default(cuid())
  title         String
  description   String?
  isActive      Boolean              @default(true)
  allowMultiple Boolean              @default(false)
  startsAt      DateTime             @default(now())
  endsAt        DateTime?
  createdById   String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  options       ResidentPollOption[]
  votes         ResidentPollVote[]

  @@index([isActive, startsAt])
  @@index([endsAt])
}

model ResidentPollOption {
  id        String             @id @default(cuid())
  pollId    String
  text      String
  sortOrder Int                @default(0)
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  poll      ResidentPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes     ResidentPollVote[]

  @@index([pollId, sortOrder])
}

model ResidentPollVote {
  id        String             @id @default(cuid())
  pollId    String
  optionId  String
  userId    String
  votedAt   DateTime           @default(now())
  poll      ResidentPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option    ResidentPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId, optionId])
  @@index([pollId, userId])
  @@index([optionId])
}
